{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "Disable all non-security updates — only open PRs for vulnerability fixes",
      "matchUpdateTypes": ["major", "minor", "patch", "digest", "pin"],
      "enabled": false
    }
  ]
}
