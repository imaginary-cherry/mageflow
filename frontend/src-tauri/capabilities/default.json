{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/mageflow-server",
          "sidecar": true,
          "args": [
            "--port",
            { "validator": "^\\d+$" },
            "--host",
            "127.0.0.1",
            "--hatchet-api-key",
            { "validator": "\\S+" },
            "--redis-url",
            { "validator": "\\S+" }
          ]
        }
      ]
    }
  ]
}
