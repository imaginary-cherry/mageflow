{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "shell:deny-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "mageflow-server",
          "sidecar": true,
          "args": [
            "--port",
            { "validator": "^\\d+$" },
            "--host",
            "127.0.0.1"
          ]
        }
      ]
    }
  ]
}
